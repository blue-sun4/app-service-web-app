# ============================================================================
# Azure Deployment Configuration
# ============================================================================
#
# Store your deployment settings here (DO NOT commit to git)
# Use environment variables or command-line arguments to override
#
# Add to .gitignore: .azure/config.env
#
# ============================================================================

# Azure Subscription (auto-detected from az login if not set)
# AZURE_SUBSCRIPTION_ID=""

# Resource Group (auto-detected if only one exists)
# AZURE_RESOURCE_GROUP=""

# Static Web App Name (auto-detected if only one exists)
# AZURE_STATIC_WEB_APP=""

# Build Directory
AZURE_BUILD_DIR="./dist"

# Node Version for deployment
NODE_VERSION="20"

# Yarn/NPM
PACKAGE_MANAGER="yarn"  # or "npm"

# App location in repo
APP_LOCATION="/"

# Build output location
OUTPUT_LOCATION="dist"
